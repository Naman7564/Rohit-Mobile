# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production-12345678901234567890
DJANGO_SETTINGS_MODULE=rohit_mobile_project.settings
ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx,yourdomain.com

# Database (SQLite is default, can switch to PostgreSQL)
DATABASE_URL=sqlite:///db.sqlite3

# AI Configuration
AI_PROVIDER=openai  # Options: openai, google, anthropic
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-genai-api-key
ANTHROPIC_API_KEY=your-anthropic-claude-api-key

# Server Configuration
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# SSL/HTTPS (for production)
# nginx_ssl=true
# nginx_ssl_cert=/path/to/cert.pem
# nginx_ssl_key=/path/to/key.pem
